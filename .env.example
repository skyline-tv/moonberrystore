# Storefront (Vite — safe to expose in the browser)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_token
VITE_SHOPIFY_API_VERSION=2025-01

# Checkout API (server only — set in Vercel, never commit real values)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_token
SHOPIFY_API_VERSION=2025-01

# COD orders — Dev Dashboard (2026, recommended):
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_your_client_secret

# Or legacy Admin token (old “Develop apps” flow, if you still have one):
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_token

# Razorpay (UPI / card on your custom checkout)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
VITE_CONTACT_EMAIL=moonberry.bussness@gmail.com
VITE_CONTACT_PHONE=+91 90000 00000
